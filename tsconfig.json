{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "module": "Node16",
    "moduleResolution": "Node16",
    "types": ["node"]
  },
  "exclude": ["node_modules", "dist", ".next"]
}
